# CosmOS — переменные окружения
# Скопируй в .env и заполни значениями.
# .env НЕ должен попадать в Git.

# ── LLM Providers ──────────────────────────────────

# OpenRouter
OPENROUTER_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (Codex)
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# xAI / Grok
XAI_API_KEY=

# Z.AI / GLM
GLM_API_KEY=

# ── Agent CLI paths (если не в PATH) ───────────────

HERMES_BIN=hermes
CLAUDE_BIN=claude
CODEX_BIN=codex
OPENCODE_BIN=opencode

# ── Telegram (Phase 4) ─────────────────────────────

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Obsidian ───────────────────────────────────────

OBSIDIAN_VAULT_PATH=~/Sync/Obsidian/Mobile

# ── Mem0 (опционально) ─────────────────────────────

MEM0_API_KEY=

# ── Vector DB (опционально) ────────────────────────

VECTOR_DB_URL=
VECTOR_DB_KEY=

# ── Google Workspace (опционально) ────────────────

GOOGLE_CLIENT_SECRET_PATH=
GOOGLE_TOKEN_PATH=

# ── NotebookLM (опционально) ───────────────────────

NOTEBOOKLM_STORAGE_STATE=~/.notebooklm/profiles/default/storage_state.json
